@{
}
<h2 style="text-align:center;">Feedback Form</h2>

<div style="width:400px; margin:auto; border:1px solid #ccc; padding:20px; border-radius:8px;">

    <form method="post" action="/feedback/submit">

        <label>Name</label><br />
        <input type="text" name="name" style="width:100%; padding:8px; margin-bottom:10px;" /><br />

        <label>Comments</label><br />
        <textarea name="comments" style="width:100%; padding:8px; margin-bottom:10px;"></textarea><br />

        <label>Rating (1–5)</label><br />
        <input type="number" name="rating" min="1" max="5" style="width:100%; padding:8px; margin-bottom:15px;" /><br />

        <button type="submit" style="width:100%; padding:10px; background-color:#17A2B8; color:white; border:none; border-radius:5px;">
            Submit Feedback
        </button>

    </form>

    @if (ViewData["Message"] != null)
    {
        <h3 style="text-align:center; margin-top:20px; color:blue;">
            @ViewData["Message"]
        </h3>
    }

</div>